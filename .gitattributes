# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.toml text eol=lf
*.sh text eol=lf

# Windows batch scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.class binary
