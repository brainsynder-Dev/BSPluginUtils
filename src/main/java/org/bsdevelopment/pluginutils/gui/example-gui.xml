<?xml version="1.0" encoding="UTF-8"?>
<!--
    Example GUI — new xml/ format (XmlGuiManager / XmlGuiDefinition).

    This file was previously written for the deprecated v1 gui/ system.
    It has been updated to the current <slots>/<slot> schema.

    Load it with:
        XmlGuiManager guiManager = new XmlGuiManager(plugin);
        XmlGui gui = guiManager.load(new File(getDataFolder(), "example-gui.xml"));
        gui.open(player);
-->
<gui title="&eExample GUI" rows="3">

    <definitions>

        <!-- Powerful custom sword with enchants, attributes, flags, and persistent data -->
        <item id="poweredSword" material="DIAMOND_SWORD" amount="1"
              name="&cPowered Sword" unbreakable="true">
            <lore>
                <line>Electrified</line>
                <line>Handle with care</line>
            </lore>

            <flags>
                <flag>HIDE_ENCHANTS</flag>
                <flag>HIDE_ATTRIBUTES</flag>
            </flags>

            <enchants>
                <enchant type="minecraft:sharpness" level="5"/>
                <enchant type="minecraft:unbreaking" level="3"/>
            </enchants>

            <attributes>
                <attribute attribute="minecraft:generic_attack_damage"
                           amount="8.0" operation="ADD_NUMBER" slot="HAND"/>
            </attributes>

            <persistent-data-list>
                <persistent-data key="owner"      type="STRING">Player123</persistent-data>
                <persistent-data key="isActive"   type="BOOLEAN">true</persistent-data>
                <persistent-data key="powerLevel" type="INT">42</persistent-data>
                <persistent-data key="smallByte"  type="BYTE">7</persistent-data>
                <persistent-data key="ratio"      type="DOUBLE">0.75</persistent-data>
                <persistent-data key="speed"      type="FLOAT">1.5</persistent-data>
                <persistent-data key="bigNum"     type="LONG">1234567890123</persistent-data>
                <persistent-data key="shortVal"   type="SHORT">123</persistent-data>
            </persistent-data-list>

            <nbt-json>{"CustomModelData":99}</nbt-json>
        </item>

        <!-- Custom textured player head -->
        <item id="customSkull" material="PLAYER_HEAD" amount="1" name="&bCool Skull"
              skull-texture="http://textures.minecraft.net/texture/abcd1234ef5678...">
            <lore>
                <line>Right-click to wear</line>
            </lore>

            <flags>
                <flag>HIDE_ATTRIBUTES</flag>
            </flags>

            <persistent-data-list>
                <persistent-data key="skullType" type="STRING">hero</persistent-data>
            </persistent-data-list>
        </item>

    </definitions>

    <slots>

        <!-- Slot 10: give the powered sword -->
        <slot index="10" item="poweredSword">
            <actions>
                <action type="message">&aYou picked up the Powered Sword!</action>
                <action type="give" item="poweredSword" amount="1"/>
                <action type="close"/>
            </actions>
        </slot>

        <!-- Slot 13: give the custom skull -->
        <slot index="13" item="customSkull">
            <actions>
                <action type="give" item="customSkull" amount="1"/>
            </actions>
        </slot>

        <!-- Slot 22: inline item defined directly on the slot -->
        <slot index="22" material="GOLD_INGOT" amount="5" name="&6Gold Ingot">
            <lore>
                <line>Shiny</line>
                <line>Worth less than diamonds</line>
            </lore>

            <flags>
                <flag>HIDE_ENCHANTS</flag>
            </flags>

            <enchants>
                <enchant type="minecraft:luck" level="1"/>
            </enchants>

            <actions>
                <action type="give">GOLD_INGOT 5</action>
            </actions>
        </slot>

    </slots>

</gui>
